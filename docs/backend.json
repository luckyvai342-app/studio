
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and wallet information",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "freeFireId": { "type": "string" },
        "phone": { "type": "string" },
        "walletBalance": { "type": "number" },
        "lastActionAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "freeFireId", "phone", "walletBalance"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "Match details and prize information",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "entryFee": { "type": "number" },
        "totalPrize": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "ongoing", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "maxPlayers": { "type": "number" },
        "joinedCount": { "type": "number" },
        "map": { "type": "string" },
        "type": { "type": "string", "enum": ["Solo", "Duo", "Squad"] },
        "imageUrl": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial records for deposits and fees",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "entry_fee", "prize"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "referenceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "createdAt"]
    },
    "PaymentOrder": {
      "title": "Payment Order",
      "description": "Razorpay order tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "razorpayOrderId": { "type": "string", "description": "The unique order ID from Razorpay" },
        "razorpayPaymentId": { "type": "string", "description": "The unique payment ID from Razorpay (set after success)" },
        "status": { "type": "string", "enum": ["created", "paid", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "razorpayOrderId", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System-wide security and activity logs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "WebhookEvent": {
      "title": "Webhook Event",
      "description": "Idempotency tracking for payment events",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "processedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profile and balance"
    },
    "/tournaments/{tournamentId}": {
      "schema": "#/entities/Tournament",
      "description": "Main tournament metadata"
    },
    "/tournaments/{tournamentId}/participants/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "kills": { "type": "number" },
          "joinedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Participants list"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "#/entities/Transaction",
      "description": "User financial history"
    },
    "/paymentOrders/{orderId}": {
      "schema": "#/entities/PaymentOrder",
      "description": "Razorpay order records"
    },
    "/webhook_events/{eventId}": {
      "schema": "#/entities/WebhookEvent",
      "description": "Idempotency logs"
    },
    "/audit_logs/{logId}": {
      "schema": "#/entities/AuditLog",
      "description": "Security audit trails"
    }
  }
}
