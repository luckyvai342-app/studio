
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and battle identity",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "App display name" },
        "gameUsername": { "type": "string", "description": "Free Fire In-game Name" },
        "gameUid": { "type": "string", "description": "Free Fire numeric UID" },
        "gameRegion": { "type": "string", "enum": ["India", "Bangladesh", "Pakistan", "Nepal"] },
        "accountVerified": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "suspended", "banned"] },
        "phone": { "type": "string" },
        "walletBalance": { "type": "number" },
        "lastUidUpdate": { "type": "string", "format": "date-time" },
        "lastActionAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "gameUid", "phone", "walletBalance"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "Match details and prize information",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "entryFee": { "type": "number" },
        "totalPrize": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "full", "ongoing", "completed", "cancelled"] },
        "startTime": { "type": "string", "format": "date-time" },
        "maxPlayers": { "type": "number" },
        "joinedCount": { "type": "number" },
        "map": { "type": "string" },
        "type": { "type": "string", "enum": ["Solo", "Duo", "Squad"] },
        "imageUrl": { "type": "string" },
        "roomId": { "type": "string" },
        "roomPassword": { "type": "string" },
        "resultsUploaded": { "type": "boolean" }
      }
    },
    "PlayerStats": {
      "title": "Player Stats",
      "description": "Global aggregate performance statistics",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "totalMatches": { "type": "number" },
        "totalKills": { "type": "number" },
        "totalWins": { "type": "number" },
        "totalScore": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "A single entry in a match-specific leaderboard",
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "rank": { "type": "number" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "kills": { "type": "number" },
        "score": { "type": "number" },
        "position": { "type": "number" },
        "prizeWon": { "type": "number" },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profile and battle identity"
    },
    "/playerStats/{userId}": {
      "schema": "#/entities/PlayerStats",
      "description": "Global aggregate performance statistics"
    },
    "/tournaments/{tournamentId}": {
      "schema": "#/entities/Tournament",
      "description": "Main tournament metadata"
    },
    "/tournaments/{tournamentId}/participants/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "username": { "type": "string" },
          "gameUid": { "type": "string" },
          "gameUsername": { "type": "string" },
          "kills": { "type": "number" },
          "placement": { "type": "number" },
          "score": { "type": "number" },
          "prizeWon": { "type": "number" },
          "joinedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Participants list with performance data"
    },
    "/leaderboards/{matchId}/entries/{userId}": {
      "schema": "#/entities/LeaderboardEntry",
      "description": "Match specific leaderboard snapshots"
    }
  }
}
