rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Protection against replay attacks and rapid spamming
    function isNotRateLimited(userId) {
      let lastAction = get(/databases/$(database)/documents/users/$(userId)).data.lastActionAt;
      return lastAction == null || duration.value(request.time - lastAction) > duration.value(2, 's');
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Initial profile creation
      allow create: if isOwner(userId) 
                    && request.resource.data.walletBalance == 0;
      
      // PROTECTING WALLET: Only allow updating username/id/phone. 
      // walletBalance can only be changed by Admin or a System Transaction (via Admin SDK)
      allow update: if isOwner(userId) 
                    && request.resource.data.walletBalance == resource.data.walletBalance
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'freeFireId', 'phone', 'lastActionAt'])
                    || isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /participants/{userId} {
        allow read: if isAuthenticated();
        
        // Strict join logic validation
        allow create: if isOwner(userId) 
                      && !exists(/databases/$(database)/documents/tournaments/$(tournamentId)/participants/$(userId))
                      && request.resource.data.kills == 0
                      && isNotRateLimited(userId);
        
        allow update, delete: if isAdmin();
      }
    }

    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can only request pending financial actions
      allow create: if isOwner(userId) 
                    && request.resource.data.status == 'pending'
                    && (request.resource.data.type == 'deposit' || request.resource.data.type == 'withdrawal')
                    && isNotRateLimited(userId);
      
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      // Audit logs are read-only for admins to prevent record tampering
      allow read: if isAdmin();
      // Users can append logs (system events) but never edit or delete
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}