
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- User Profile Rules ---
    
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      
      allow create: if isAuthenticated() && request.auth.uid == userId 
                    && request.resource.data.walletBalance == 0
                    && request.resource.data.role == 'user';
      
      allow update: if isAdmin() || (
        isAuthenticated() && request.auth.uid == userId 
        && request.resource.data.walletBalance == resource.data.walletBalance
        && request.resource.data.role == resource.data.role
      );

      match /transactions/{transactionId} {
        allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
        allow write: if isAdmin(); 
      }
    }

    // --- Support for collectionGroup queries ---
    // This allows admins to query subcollections across the entire database
    match /{path=**}/transactions/{transactionId} {
      allow read: if isAdmin();
    }
    
    match /{path=**}/resultSubmissions/{submissionId} {
      allow read: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /playerStats/{userId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- Tournament Rules ---
    
    match /tournaments/{tournamentId} {
      allow get, list: if true; 
      allow write: if isAdmin();

      match /participants/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update, delete: if isAdmin();
      }

      match /resultSubmissions/{submissionId} {
        allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // --- Audit & Payments ---

    match /paymentOrders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /webhook_events/{eventId} {
      allow read, write: if false; 
    }
  }
}
