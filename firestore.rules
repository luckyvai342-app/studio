
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.admin == true
      );
    }

    function isParticipant(tournamentId) {
      return exists(/databases/$(database)/documents/tournaments/$(tournamentId)/participants/$(request.auth.uid));
    }

    // --- User Profile Rules ---
    
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) 
                    && request.resource.data.walletBalance == 0
                    && request.resource.data.accountVerified == false;
      
      allow update: if (
        isOwner(userId) 
        && request.resource.data.walletBalance == resource.data.walletBalance
        && request.resource.data.accountVerified == resource.data.accountVerified
        && request.resource.data.status == resource.data.status
      ) || isAdmin();

      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        // Writes only via server actions
        allow write: if false;
      }
    }

    // --- Tournament Rules ---
    
    match /tournaments/{tournamentId} {
      // Sensitive room data is protected by checking status and participation
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow write: if isAdmin();

      match /participants/{userId} {
        allow read: if isAuthenticated();
        // Create handled by server action, but we keep basic safety here
        allow create: if isOwner(userId) && !exists(/databases/$(database)/documents/tournaments/$(tournamentId)/participants/$(userId));
        allow update, delete: if isAdmin();
      }
    }

    // --- Audit & Payments ---

    match /paymentOrders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); 
    }
    
    match /webhook_events/{eventId} {
      allow read, write: if false; 
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
