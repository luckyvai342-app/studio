
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin check - used for Server Actions/Backend logic in this environment
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Protection against rapid spamming
    function isNotRateLimited(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return !exists(/databases/$(database)/documents/users/$(userId)) || 
             userDoc.data.lastActionAt == null || 
             duration.value(request.time - userDoc.data.lastActionAt) > duration.value(2, 's');
    }

    // --- User Profile Rules ---
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Users can only create a profile with 0 balance
      allow create: if isOwner(userId) 
                    && request.resource.data.walletBalance == 0;
      
      // CRITICAL: Users can NEVER update their own walletBalance.
      // Only Admin (Server Actions) can update balance.
      allow update: if (
        isOwner(userId) 
        && request.resource.data.walletBalance == resource.data.walletBalance
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'freeFireId', 'phone', 'lastActionAt'])
      ) || isAdmin();
    }

    // --- Transaction Rules ---
    
    match /users/{userId}/transactions/{transactionId} {
      // Users can only read their own financial history
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create a 'pending' withdrawal request
      allow create: if isOwner(userId) 
                    && request.resource.data.status == 'pending'
                    && request.resource.data.amount > 0
                    && request.resource.data.type == 'withdrawal'
                    && isNotRateLimited(userId);
      
      // Only admin can mark transactions as 'completed' or 'failed'
      allow update, delete: if isAdmin();
    }

    // Allow collectionGroup queries for Admins to process withdrawals
    match /{path=**}/transactions/{transactionId} {
      allow list: if isAdmin();
    }

    // --- Razorpay Payment Order Rules ---
    
    match /paymentOrders/{orderId} {
      // User can see their own orders
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // User creates the order record initially
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'created';
      
      // Only the backend (Admin) can mark an order as 'paid'
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Tournament Rules ---
    
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /participants/{userId} {
        allow read: if isAuthenticated();
        
        // Joining logic is handled atomically in code, 
        // but rules prevent users from setting their own kills/damage.
        allow create: if isOwner(userId) 
                      && !exists(/databases/$(database)/documents/tournaments/$(tournamentId)/participants/$(userId))
                      && request.resource.data.kills == 0
                      && isNotRateLimited(userId);
        
        allow update, delete: if isAdmin();
      }
    }

    // --- System Logs ---
    
    match /webhook_events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
