
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Protection against rapid spamming
    function isNotRateLimited(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return !exists(/databases/$(database)/documents/users/$(userId)) || 
             userDoc.data.lastActionAt == null || 
             duration.value(request.time - timestamp.value(userDoc.data.lastActionAt)) > duration.value(2, 's');
    }

    // Validation for Battle Account Cooldown (24 hours)
    function canUpdateUid(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return userDoc.data.lastUidUpdate == null || 
             duration.value(request.time - timestamp.value(userDoc.data.lastUidUpdate)) > duration.value(24, 'h');
    }

    // --- User Profile Rules ---
    
    match /users/{userId} {
      allow get: if isAuthenticated(); // Allow search by gameUid for verification
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) 
                    && request.resource.data.walletBalance == 0
                    && request.resource.data.accountVerified == false;
      
      allow update: if (
        isOwner(userId) 
        // Prevent manual balance edits
        && request.resource.data.walletBalance == resource.data.walletBalance
        && request.resource.data.accountVerified == resource.data.accountVerified
        // Enforce 24h cooldown if UID is changed
        && (request.resource.data.gameUid == resource.data.gameUid || canUpdateUid(userId))
      ) || isAdmin();
    }

    // --- Tournament Rules ---
    
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /participants/{userId} {
        allow read: if isAuthenticated();
        
        allow create: if isOwner(userId) 
                      && !exists(/databases/$(database)/documents/tournaments/$(tournamentId)/participants/$(userId))
                      && request.resource.data.kills == 0
                      // Ensure Battle Account is linked before joining
                      && get(/databases/$(database)/documents/users/$(userId)).data.gameUid != null;
        
        allow update, delete: if isAdmin();
      }
    }

    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.type == 'withdrawal';
      allow update, delete: if isAdmin();
    }

    match /paymentOrders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
